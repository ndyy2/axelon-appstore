{
  "name": "arch-app-store",
  "version": "1.0.0",
  "description": "Elegant Flatpak App Store for Arch Linux",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "start": "electron .",
    "package": "vite build && electron-builder --linux"
  },
  "keywords": [
    "flatpak",
    "app-store",
    "arch-linux"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.2",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.axelon.store",
    "productName": "Axelon Store",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "icon": "public/icon.png"
    }
  }
}
